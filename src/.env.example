# ── PaTavo microservicios — variables de entorno ──────────────────
# Copia este archivo a .env y ajusta los valores en producción.

# Puerto público donde Nginx expone el front + la API.
WEB_PORT=8080

# Credenciales de PostgreSQL (las consumen db y los microservicios).
POSTGRES_USER=patavo
POSTGRES_PASSWORD=patavo
POSTGRES_DB=patavo

# Secreto JWT compartido por todos los servicios (¡cámbialo!).
JWT_SECRET=patavo-shared-secret
